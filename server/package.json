{
  "name": "mindquest-backend",
  "version": "1.0.0",
  "description": "MindQuest Backend API - Mental wellness with AI",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "node test-api.js",
    "test:chat": "curl -X POST http://localhost:5000/api/chat -H \"Content-Type: application/json\" -d '{\"message\":\"Hello\"}'",
