// lib/core/constants/secrets.dart.example
//
// SETUP INSTRUCTIONS:
// 1. Copy this file to secrets.dart  (same directory)
// 2. Replace every placeholder value with your real credentials
// 3. Never commit secrets.dart — it is already in .gitignore
//
// Get your keys from:
//   Supabase  → https://app.supabase.com → Project Settings → API
//   Groq/AI   → https://console.groq.com → API Keys

class Secrets {
  // Supabase
  static const String supabaseUrl = 'https://YOUR_PROJECT_ID.supabase.co';
  static const String supabaseAnonKey = 'YOUR_SUPABASE_ANON_KEY';

  // AI / Gemini (Groq endpoint)
  static const String geminiApiKey = 'YOUR_GROQ_OR_GEMINI_API_KEY';
}
