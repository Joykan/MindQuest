<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MindQuest - Mental Wellness AI</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div id="app">
        <header>
            <h1>MindQuest</h1>
            <div class="api-status" id="api-status">Checking connection...</div>
        </header>
        
        <main>
            <!-- Your existing content here -->
            <div id="chatContainer"></div>
            
            <!-- Example forms -->
            <section>
                <h2>Journal</h2>
                <form id="journal-form">
                    <textarea id="journal-text" placeholder="How are you feeling today?" rows="4"></textarea>
                    <select id="journal-mood">
                        <option value="">Select mood</option>
                        <option value="happy">Happy</option>
                        <option value="sad">Sad</option>
                        <option value="anxious">Anxious</option>
                        <option value="calm">Calm</option>
                    </select>
                    <button type="submit">Save & Analyze</button>
                </form>
                <div id="insights-container"></div>
            </section>
            
            <section>
                <h2>Chat with AI</h2>
                <form id="chat-form">
                    <input type="text" id="chat-input" placeholder="Type your message...">
                    <button type="submit">Send</button>
                </form>
            </section>
            
            <section>
                <h2>Quick Mood Check</h2>
                <textarea id="mood-text" placeholder="How are you feeling right now?" rows="3"></textarea>
                <button id="analyze-mood-btn">Analyze Mood</button>
            </section>
        </main>
        
        <footer>
            <p>MindQuest &copy; 2025 - Mental Wellness Assistant</p>
        </footer>
    </div>
    
    <!-- API Configuration MUST be first -->
    <script src="js/api-config.js"></script>
    
    <!-- Then main application logic -->
    <script type="module" src="js/main.js"></script>
    <script type="module" src="js/app.js"></script>
    <script type="module" src="js/lang.js"></script>
    <script type="module" src="js/voice.js"></script>
    
    <!-- Initialize -->
    <script>
        console.log('MindQuest loading...');
    </script>
</body>
</html>