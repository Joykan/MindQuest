{
  "version": 2,
  "name": "mindquest",
  "builds": [
    {
      "src": "client/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "client/**/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "client/**/*.css",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/client/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://your-render-app.onrender.com",
    "VITE_APP_NAME": "MindQuest",
    "VITE_ENABLE_ANALYTICS": "false"
  }
}
